# Mailchimp API Configuration
# Get your API key from: https://mailchimp.com/account/api/

# Required: Your Mailchimp API Key
MAILCHIMP_API_KEY=your_api_key_here

# Optional: API Base URL (default: https://api.mailchimp.com)
MAILCHIMP_BASE_URL=https://api.mailchimp.com

# Optional: API Version (default: 3.0)
MAILCHIMP_API_VERSION=3.0
